# hokeypokey credentials — copy to .env and fill in real values
# .env is gitignored; never commit actual credentials.

# LDAP bind password (referenced in config as bind_password_env = "LDAP_BIND_PASSWORD")
LDAP_BIND_PASSWORD=

# GitHub personal access token with read:user scope
# (referenced in config as token_env = "GITHUB_TOKEN")
GITHUB_TOKEN=
